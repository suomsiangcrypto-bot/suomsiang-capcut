{
  "name": "suomsiang-capcut",
  "version": "1.0.0",
  "description": "SUOMSIANG CAPCUT — music & video player desktop app",
  "author": "SUOMSIANG",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "build": {
    "appId": "com.suomsiang.capcut",
    "productName": "SUOMSIANG CAPCUT",
    "files": [
      "main.js",
      "index.html",
      "favicon.ico",
      "icon.ico"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "icon.ico",
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "portable": {
      "artifactName": "SUOMSIANG-CAPCUT-Portable-${version}.exe"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SUOMSIANG CAPCUT"
    }
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0"
  }
}
